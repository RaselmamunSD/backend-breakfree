{
  "info": {
    "name": "Break Free API",
    "description": "Set `wellness_plan_id` and `premium_plan_id` from GET /api/subscription-plans/ and GET /api/premium/plans/ (first item id), or use scripts/run_postman_collection.py. Restore Purchase returns 503 unless DEBUG or RESTORE_PURCHASE_TRUST_RECEIPT=true. OTP/Firebase need real credentials.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/api/auth/register/",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"rasel\",\n  \"email\": \"rasel@example.com\",\n  \"full_name\": \"Rasel Mamun\",\n  \"phone\": \"01700000000\",\n  \"password\": \"12345678\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is successful 200/201/204\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);",
              "});",
              "",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.access) {",
              "        pm.collectionVariables.set(\"access_token\", jsonData.access);",
              "    } else if (jsonData.token) {",
              "        pm.collectionVariables.set(\"access_token\", jsonData.token);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"test_username\", \"user_\" + pm.variables.replaceIn(\"{{}}\"));",
              "pm.collectionVariables.set(\"test_email\", \"email_\" + pm.variables.replaceIn(\"{{}}\") + \"@example.com\");"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
